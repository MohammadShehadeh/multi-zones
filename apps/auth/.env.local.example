# Required: signing key for cookies and JWT session payload (min 32 chars in production)
AUTH_SECRET=

# Public URL of this app's Better Auth base (must include /api/auth path)
BETTER_AUTH_URL=http://localhost:3003/api/auth

# Upstream IdP login endpoint (POST JSON { username, password })
EXTERNAL_API_URL=https://external-api.com/login

# Optional: share cookies across subdomains (e.g. .example.com)
AUTH_COOKIE_DOMAIN=

# lax | none — use none only with Secure cookies and explicit trusted origins
AUTH_COOKIE_SAMESITE=lax

# Comma-separated browser origins allowed to call these APIs with credentials
AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3003
